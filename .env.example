POLL_INTERVAL_SECONDS=600
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/watchagent.db
ENABLE_POLLER=true
HOST_PORT=8000
OPEN_METEO_ARCHIVE_BASE_URL=https://archive-api.open-meteo.com/v1/archive
ENABLE_FORECAST_RECONCILIATION=true

# Only used by .cursor/skills/data-analysis, not by the running service.
# Do not commit a real key.
ANTHROPIC_API_KEY=
